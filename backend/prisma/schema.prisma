generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== MODELS ==============

model Camp {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  troops    Troop[]
  users     User[]
  schedules Schedule[]
}

model Troop {
  id        String   @id @default(uuid())
  name      String
  number    Int
  campId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  camp      Camp     @relation(fields: [campId], references: [id])
  squads    Squad[]
}

model Squad {
  id        String   @id @default(uuid())
  name      String
  number    Int
  troopId   String
  leaderId  String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  troop     Troop    @relation(fields: [troopId], references: [id])
  leader    User?    @relation("SquadLeader", fields: [leaderId], references: [id])
  scouts    Scout[]
  schedules Schedule[]
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  password     String
  role         String
  name         String
  campId       String?

  camp         Camp? @relation(fields: [campId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  leadingSquad Squad?   @relation("SquadLeader")
  staffActivity Activity? @relation("StaffActivity")
  auditLogs    AuditLog[]
  scoutAccount Scout?   @relation("ScoutUser")
}

model Scout {
  id         String   @id @default(uuid())
  scoutCode  String   @unique
  firstName  String
  lastName   String
  nickname   String?
  birthDate  DateTime?
  school     String?
  province   String?
  phone      String?
  email      String?
  squadId    String?
  userId     String?  @unique
  qrData     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  squad      Squad?   @relation(fields: [squadId], references: [id])
  user       User?    @relation("ScoutUser", fields: [userId], references: [id])
  attendances Attendance[]
}

model Activity {
  id          String       @id @default(uuid())
  name        String
  type        String
  description String?
  staffId     String?      @unique
  maxScans    Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  staff       User?        @relation("StaffActivity", fields: [staffId], references: [id])
  attendances Attendance[]
  schedules   Schedule[]
}

model Schedule {
  id         String   @id @default(uuid())
  activityId String
  campId     String
  squadId    String?
  date       DateTime
  slot       String   // "MORNING" | "AFTERNOON" | "EVENING"
  createdAt  DateTime @default(now())

  activity   Activity @relation(fields: [activityId], references: [id])
  camp       Camp     @relation(fields: [campId], references: [id])
  squad      Squad?   @relation(fields: [squadId], references: [id])
}

model Attendance {
  id         String     @id @default(uuid())
  scoutId    String
  activityId String
  result     String     @default("PASS")
  outOfSchedule Boolean @default(false)
  scannedAt  DateTime   @default(now())
  scannedBy  String?

  scout      Scout    @relation(fields: [scoutId], references: [id])
  activity   Activity @relation(fields: [activityId], references: [id])

  @@unique([scoutId, activityId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  target    String?
  before    String?
  after     String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}
